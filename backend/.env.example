# Server Configuration
HOST=127.0.0.1
PORT=5001
ENVIRONMENT=development

# MongoDB Atlas Connection
# Replace with your MongoDB Atlas details or use local: mongodb://localhost:27017/video_synopsis_ai
MONGODB_URL=
MONGODB_DB_NAME=video_synopsis_ai

# JWT Security Configuration
# Generate key using: openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=52560000

# External AI and API Keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
YOUTUBE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
